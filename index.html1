<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shop Window Blinds Dubai – Dubai Blinds Co.</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--gold:#C9A55A;--gold-light:#E8D5A3;--dark:#0D0D0D;--dark2:#131313;--dark3:#1A1A1A;--dark4:#242424;--white:#F5F2EC;--muted:#9A9790;--border:rgba(201,165,90,0.15)}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--dark);color:var(--white);overflow-x:hidden;line-height:1.7}
a{color:inherit;text-decoration:none}
img{display:block;width:100%;object-fit:cover}
.tag{font-size:.7rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:.7rem;display:block}
.divider{width:55px;height:2px;background:var(--gold);margin:1.2rem 0 1.5rem}
.btn-gold{display:inline-block;background:var(--gold);color:var(--dark);padding:.85rem 2rem;font-size:.85rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;border-radius:2px;transition:all .3s}
.btn-gold:hover{background:var(--gold-light);transform:translateY(-2px)}
.btn-outline{display:inline-block;border:1px solid rgba(201,165,90,.5);color:var(--gold);padding:.85rem 2rem;font-size:.85rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;border-radius:2px;transition:all .3s}
.btn-outline:hover{border-color:var(--gold);background:rgba(201,165,90,.07)}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1.1rem 4rem;background:rgba(13,13,13,0.95);border-bottom:1px solid var(--border);backdrop-filter:blur(16px)}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.45rem;font-weight:700;color:var(--gold);letter-spacing:.03em}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.82rem;font-weight:400;letter-spacing:.07em;text-transform:uppercase;color:var(--white);transition:color .3s}
.nav-links a:hover{color:var(--gold)}
.nav-cta{background:var(--gold)!important;color:var(--dark)!important;padding:.55rem 1.3rem;border-radius:2px;font-weight:600!important}

/* OFFER STRIP */
.offer-strip{background:var(--gold);text-align:center;padding:.75rem 2rem;font-size:.82rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--dark);margin-top:66px}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:5rem 4rem;background:var(--dark)}
.hero-right{position:relative;overflow:hidden}
.hero-right img{height:100%;width:100%;object-fit:cover;filter:brightness(.75)}
.hero-right::after{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to right,var(--dark) 0%,transparent 40%)}
.hero-badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(201,165,90,.1);border:1px solid rgba(201,165,90,.3);color:var(--gold);font-size:.75rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:.45rem 1rem;border-radius:2px;margin-bottom:1.8rem;width:fit-content}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.6rem,4.5vw,4.2rem);font-weight:900;line-height:1.06;margin-bottom:1.2rem}
.hero h1 .gold{color:var(--gold);font-style:italic}
.hero-sub{font-size:1.05rem;color:var(--muted);font-weight:300;max-width:480px;margin-bottom:2rem;line-height:1.75}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3rem}
.hero-stats{display:flex;gap:2.5rem;padding-top:2.5rem;border-top:1px solid var(--border)}
.stat-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--gold);line-height:1}
.stat-label{font-size:.7rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-top:.3rem}

/* INTRO */
.intro-section{padding:6rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;background:var(--dark2)}
.intro-img{border-radius:4px;overflow:hidden;position:relative;height:480px}
.intro-img img{height:100%;width:100%;object-fit:cover}
.intro-img-badge{position:absolute;bottom:1.8rem;left:1.8rem;background:var(--gold);color:var(--dark);padding:.7rem 1.2rem;border-radius:2px;font-size:.82rem;font-weight:700;letter-spacing:.05em}
.intro-content h2{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3vw,2.8rem);font-weight:700;line-height:1.12;margin-bottom:1.2rem}
.intro-content p{font-size:.95rem;color:var(--muted);line-height:1.8;margin-bottom:1rem}
.intro-features{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin:2rem 0}
.intro-feat{display:flex;align-items:center;gap:.6rem;font-size:.85rem;color:var(--white)}
.intro-feat::before{content:'✓';color:var(--gold);font-weight:700;font-size:.9rem;flex-shrink:0}

/* PRODUCTS */
.products-section{padding:6rem 4rem;background:var(--dark3)}
.sec-header{text-align:center;max-width:650px;margin:0 auto 3.5rem}
.sec-header .divider{margin:1.2rem auto 1.5rem}
.sec-header h2{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3vw,2.8rem);font-weight:700;line-height:1.12}
.sec-header p{font-size:.95rem;color:var(--muted)}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem}
.product-card{background:var(--dark2);border:1px solid var(--border);border-radius:4px;overflow:hidden;transition:all .35s;display:block;color:var(--white)}
.product-card:hover{transform:translateY(-6px);border-color:rgba(201,165,90,.4);box-shadow:0 16px 40px rgba(0,0,0,.5)}
.product-img{height:200px;overflow:hidden;position:relative}
.product-img img{height:100%;width:100%;object-fit:cover;transition:transform .5s}
.product-card:hover .product-img img{transform:scale(1.07)}
.product-badge{position:absolute;top:.8rem;right:.8rem;background:var(--gold);color:var(--dark);font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.3rem .7rem;border-radius:2px}
.product-body{padding:1.4rem 1.5rem}
.product-body h3{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;margin-bottom:.5rem}
.product-body p{font-size:.82rem;color:var(--muted);line-height:1.65;margin-bottom:1rem}
.product-link{font-size:.78rem;font-weight:600;color:var(--gold);letter-spacing:.08em;text-transform:uppercase;display:inline-flex;align-items:center;gap:.4rem;transition:gap .3s}
.product-card:hover .product-link{gap:.7rem}

/* SERVICES */
.services-section{padding:6rem 4rem;background:var(--dark)}
.services-header{max-width:600px;margin-bottom:4rem}
.services-header h2{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3vw,2.8rem);font-weight:700;line-height:1.12}
.services-header p{font-size:.95rem;color:var(--muted);margin-top:1rem}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.service-card{background:var(--dark3);border:1px solid var(--border);border-radius:4px;overflow:hidden;transition:border-color .3s}
.service-card:hover{border-color:rgba(201,165,90,.4)}
.service-img{height:180px;overflow:hidden}
.service-img img{height:100%;width:100%;object-fit:cover;transition:transform .5s}
.service-card:hover .service-img img{transform:scale(1.05)}
.service-body{padding:1.4rem 1.5rem}
.service-num{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:rgba(201,165,90,.3);margin-bottom:.5rem}
.service-body h3{font-size:1rem;font-weight:600;margin-bottom:.5rem}
.service-body p{font-size:.82rem;color:var(--muted);line-height:1.65}

/* CUSTOM SHOP CARDS */
.shop-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.5rem;max-width:1100px;margin:2.5rem auto 0}
.shop-card{background:var(--dark3);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.shop-card img{height:180px;width:100%;object-fit:cover}
.shop-card-body{padding:1.2rem}
.shop-card-body h4{font-size:.95rem;font-weight:600;margin-bottom:.4rem}
.shop-card-body p{font-size:.8rem;color:var(--muted);line-height:1.6}

/* BENEFITS */
.benefits-section{padding:6rem 4rem;background:var(--dark2);display:grid;grid-template-columns:1.1fr 1fr;gap:5rem;align-items:center}
.benefits-img{border-radius:4px;overflow:hidden;height:520px;position:relative}
.benefits-img img{height:100%;width:100%;object-fit:cover}
.benefits-img-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(13,13,13,.9));padding:2rem 1.8rem}
.benefits-img-overlay span{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:.3rem}
.benefits-img-overlay strong{font-size:1.1rem;font-weight:500}
.benefits-content h2{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,2.5vw,2.4rem);font-weight:700;line-height:1.12}
.benefit-list{margin-top:2rem;display:flex;flex-direction:column;gap:1.2rem}
.benefit-item{display:flex;gap:1rem;align-items:flex-start;padding-bottom:1.2rem;border-bottom:1px solid rgba(255,255,255,.06)}
.benefit-icon{width:44px;height:44px;background:rgba(201,165,90,.1);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.benefit-item h4{font-size:.92rem;font-weight:600;margin-bottom:.25rem}
.benefit-item p{font-size:.82rem;color:var(--muted);line-height:1.6}

/* BUY ONLINE */
.buyonline-section{padding:6rem 4rem;background:var(--dark3)}
.buyonline-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.buyonline-content h2{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,2.5vw,2.4rem);font-weight:700;line-height:1.12}
.buyonline-content > p{font-size:.95rem;color:var(--muted);line-height:1.8;margin:1.2rem 0}
.steps-list{margin:2rem 0;display:flex;flex-direction:column;gap:1rem}
.step-item{display:flex;gap:1rem;align-items:flex-start}
.step-num{width:34px;height:34px;border-radius:50%;background:var(--gold);color:var(--dark);font-size:.82rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:.1rem}
.step-item h4{font-size:.9rem;font-weight:600;margin-bottom:.2rem}
.step-item p{font-size:.8rem;color:var(--muted)}
.buyonline-img{border-radius:4px;overflow:hidden;height:480px}
.buyonline-img img{height:100%;width:100%;object-fit:cover}

/* REVIEWS */
.reviews-section{padding:6rem 4rem;background:var(--dark2)}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.review-card{background:var(--dark3);border:1px solid var(--border);border-radius:4px;padding:1.8rem;position:relative;transition:border-color .3s}
.review-card:hover{border-color:rgba(201,165,90,.35)}
.review-stars{color:var(--gold);font-size:.95rem;margin-bottom:1rem;letter-spacing:.1em}
.review-text{font-size:.88rem;color:var(--muted);line-height:1.75;font-style:italic;margin-bottom:1.5rem}
.reviewer{display:flex;align-items:center;gap:.8rem}
.reviewer-av{width:40px;height:40px;border-radius:50%;background:rgba(201,165,90,.15);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:var(--gold);flex-shrink:0}
.reviewer-name{font-size:.88rem;font-weight:600}
.reviewer-loc{font-size:.74rem;color:var(--muted)}
.review-quote{position:absolute;top:1.4rem;right:1.6rem;font-size:3rem;color:rgba(201,165,90,.08);font-family:'Playfair Display',serif;line-height:1}

/* FIXING */
.fixing-section{display:grid;grid-template-columns:1fr 1fr;background:var(--dark)}
.fixing-img{height:500px;position:relative;overflow:hidden}
.fixing-img img{height:100%;width:100%;object-fit:cover;filter:brightness(.7)}
.fixing-content{padding:5rem 4rem;display:flex;flex-direction:column;justify-content:center}
.fixing-content h2{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,2.5vw,2.4rem);font-weight:700;line-height:1.12;margin-bottom:.8rem}
.fixing-content > p{font-size:.95rem;color:var(--muted);line-height:1.8;margin-bottom:2rem}
.fixing-points{display:flex;flex-direction:column;gap:1rem}
.fixing-point{display:flex;align-items:flex-start;gap:.8rem;padding:1rem;background:var(--dark3);border:1px solid var(--border);border-radius:4px}
.fixing-point-icon{font-size:1.1rem;color:var(--gold);flex-shrink:0;margin-top:.1rem}
.fixing-point h4{font-size:.9rem;font-weight:600;margin-bottom:.2rem}
.fixing-point p{font-size:.8rem;color:var(--muted);line-height:1.6}

/* WHY CHOOSE */
.wc-section{padding:6rem 4rem;background:var(--dark3);text-align:center}
.wc-section h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:700}
.wc-section > p{font-size:.95rem;color:var(--muted);max-width:560px;margin:0 auto 3.5rem}
.wc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;margin-bottom:3.5rem}
.wc-card{background:var(--dark2);border:1px solid var(--border);border-radius:4px;padding:2rem 1.5rem;transition:all .3s}
.wc-card:hover{border-color:rgba(201,165,90,.4);transform:translateY(-4px)}
.wc-icon{font-size:2rem;width:56px;height:56px;background:rgba(201,165,90,.08);border-radius:4px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.2rem}
.wc-card h4{font-size:1rem;font-weight:600;margin-bottom:.5rem}
.wc-card p{font-size:.82rem;color:var(--muted);line-height:1.65}
.wc-cta{background:linear-gradient(135deg,rgba(201,165,90,.12),rgba(201,165,90,.04));border:1px solid rgba(201,165,90,.25);border-radius:4px;padding:3rem;max-width:700px;margin:0 auto}
.wc-cta h3{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;margin-bottom:.8rem}
.wc-cta p{font-size:.92rem;color:var(--muted);margin-bottom:1.8rem;line-height:1.7}
.wc-cta .cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}

/* LISTINGS */
.listings-section{padding:5rem 4rem;background:var(--dark2)}
.listings-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:.8rem;margin-top:2.5rem}
.listing-card{background:var(--dark3);border:1px solid var(--border);border-radius:2px;padding:.8rem 1rem;display:flex;align-items:center;gap:.65rem;font-size:.8rem;color:var(--muted);transition:all .25s}
.listing-card:hover{border-color:rgba(201,165,90,.4);color:var(--gold);background:var(--dark4)}
.ldot{width:5px;height:5px;background:var(--gold);border-radius:50%;flex-shrink:0}

/* WEB2 */
.web2-section{padding:5rem 4rem;background:var(--dark)}
.web2-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:1rem;margin-top:2.5rem}
.web2-card{background:var(--dark3);border:1px solid var(--border);border-left:3px solid var(--gold);border-radius:2px;padding:1rem 1.3rem;display:flex;align-items:center;gap:.8rem;font-size:.83rem;color:var(--muted);transition:all .25s}
.web2-card:hover{color:var(--gold);background:var(--dark4)}

/* PROFILES */
.profiles-section{padding:5rem 4rem;background:var(--dark2)}
.profiles-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:.7rem;margin-top:2.5rem}
.profile-pill{background:var(--dark3);border:1px solid var(--border);border-radius:2px;padding:.65rem 1rem;text-align:center;font-size:.78rem;color:var(--muted);transition:all .25s;display:block}
.profile-pill:hover{color:var(--gold);border-color:rgba(201,165,90,.4);background:rgba(201,165,90,.04)}

/* CONTACT */
.contact-section{padding:6rem 4rem;background:var(--dark3);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.contact-section h2{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3vw,2.6rem);font-weight:700;line-height:1.12}
.contact-section > div > p{font-size:.95rem;color:var(--muted);line-height:1.8;margin:1.2rem 0 2rem}
.contact-details{display:flex;flex-direction:column;gap:1.2rem;margin-bottom:2rem}
.cdet{display:flex;align-items:flex-start;gap:1rem}
.cdet-icon{width:44px;height:44px;background:rgba(201,165,90,.1);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:var(--gold);flex-shrink:0}
.cdet strong{display:block;font-size:.7rem;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.25rem}
.cdet a,.cdet span{font-size:.95rem;color:var(--white)}
.cdet a:hover{color:var(--gold)}
.contact-map{border-radius:4px;overflow:hidden;border:1px solid var(--border);height:380px}
.contact-map iframe{width:100%;height:100%;border:none}

/* FOOTER */
footer{background:var(--dark);border-top:1px solid var(--border);padding:3rem 4rem}
.footer-top{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:3rem;margin-bottom:2.5rem}
.footer-logo{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--gold);margin-bottom:.8rem}
.footer-about{font-size:.82rem;color:var(--muted);line-height:1.7}
.footer-col h4{font-size:.75rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.footer-col ul li a{font-size:.82rem;color:var(--muted);transition:color .3s}
.footer-col ul li a:hover{color:var(--gold)}
.footer-bottom{border-top:1px solid var(--border);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.footer-copy{font-size:.76rem;color:var(--muted)}

@media(max-width:1024px){
  nav{padding:1rem 1.5rem}
  .nav-links{display:none}
  .hero{grid-template-columns:1fr}
  .hero-right{display:none}
  .hero-left{padding:5rem 1.8rem 3rem}
  .intro-section,.benefits-section,.buyonline-inner,.contact-section{grid-template-columns:1fr;gap:2.5rem}
  .fixing-section{grid-template-columns:1fr}
  .services-grid,.reviews-grid{grid-template-columns:1fr 1fr}
  .wc-grid{grid-template-columns:1fr 1fr}
  .footer-top{grid-template-columns:1fr 1fr}
  .intro-section,.products-section,.services-section,.benefits-section,.buyonline-section,.reviews-section,.fixing-content,.wc-section,.listings-section,.web2-section,.profiles-section,.contact-section,.listings-section{padding:4rem 1.8rem}
  footer{padding:2.5rem 1.8rem}
}
@media(max-width:600px){
  .services-grid,.reviews-grid,.wc-grid{grid-template-columns:1fr}
  .hero h1{font-size:2.2rem}
  .fixing-img{height:280px}
  .footer-top{grid-template-columns:1fr}
}
</style>
</head>
<body>

<nav>
  <a href="https://dubaiblindsco.com/" class="nav-logo">Dubai Blinds Co.</a>
  <ul class="nav-links">
    <li><a href="#products">Products</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#reviews">Reviews</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="tel:+971567555833" class="nav-cta">Call Now</a></li>
  </ul>
</nav>

<div class="offer-strip">🏷 Limited Time — Flat 25% OFF + Free 24-Hour Installation on All Blinds · Call: +971 567 555 833</div>

<!-- HERO — H1 -->
<section class="hero" id="home">
  <div class="hero-left">
    <div class="hero-badge">✦ Dubai's #1 Blinds Specialists</div>
    <h1>Shop Window <a href="https://dubaiblindsco.com/" class="gold">Blinds Dubai</a> For Every Home</h1>
    <p class="hero-sub">Premium custom-crafted window blinds for residential and commercial spaces across Dubai. Expert installation, superior materials, guaranteed satisfaction.</p>
    <div class="hero-actions">
      <a href="https://dubaiblindsco.com/" class="btn-gold">Explore Collection</a>
      <a href="tel:+971567555833" class="btn-outline">+971 567 555 833</a>
    </div>
    <div class="hero-stats">
      <div><div class="stat-num">5000+</div><div class="stat-label">Projects Done</div></div>
      <div><div class="stat-num">10+</div><div class="stat-label">Blind Types</div></div>
      <div><div class="stat-num">24hr</div><div class="stat-label">Installation</div></div>
      <div><div class="stat-num">100%</div><div class="stat-label">Satisfaction</div></div>
    </div>
  </div>
  <div class="hero-right">
    <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&q=85" alt="Window Blinds Dubai luxury interior">
  </div>
</section>

<!-- INTRO — H2 -->
<section class="intro-section" id="about">
  <div class="intro-img">
    <img src="https://images.unsplash.com/photo-1560448204-603b3fc33ddc?w=800&q=85" alt="Affordable quality blinds Dubai showroom">
    <div class="intro-img-badge">Flat 25% OFF — Order Today</div>
  </div>
  <div class="intro-content">
    <span class="tag">✦ About Dubai Blinds Co.</span>
